generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Booking {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  nama         String
  nim          String
  email        String
  hp           String
  instansi     String
  jabatan      String
  ruangan      String
  tanggal      String
  jamMulai     String
  jamSelesai   String
  kegiatan     String
  fileSuratUrl String
  status       String   @default("pending")
}
