// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Room ────────────────────────────────────────────────
model Room {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  namaGedung   String
  nomorRuangan String
  kategori     String
  lantai       String
  kapasitas    Int
  fasilitas    String[]
  fotoUrl      String?
  isAvailable  Boolean  @default(true)
  needsPermit  Boolean  @default(false)
  keterangan   String?
  bookings     Booking[]
}

// ─── Booking ─────────────────────────────────────────────
model Booking {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  nama         String
  nim          String
  email        String
  hp           String
  instansi     String
  jabatan      String
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id])
  userId       String?
  tanggal      String
  jamMulai     String
  jamSelesai   String
  kegiatan     String
  fileSuratUrl String
  status       String   @default("pending")
  catatanAdmin String?
}

// ─── Notification (BARU) ─────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Penerima notifikasi — userId dari Supabase Auth
  userId    String

  // Tipe notifikasi untuk ikon & warna
  // "booking_submitted" | "booking_approved" | "booking_rejected" | "booking_cancelled"
  type      String

  title     String   // "Pengajuan Diterima"
  message   String   // "Ruangan TULT — Aula Lt.2 pada 12 Jun 2025..."

  // Link ke halaman yang relevan saat notif diklik
  href      String   @default("/dashboard/peminjaman")

  // Referensi ke booking terkait (opsional)
  bookingId String?

  isRead    Boolean  @default(false)

  @@index([userId])           // Query notif by user sangat cepat
  @@index([userId, isRead])   // Query unread count sangat cepat
}