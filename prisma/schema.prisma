generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Room {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  namaGedung   String
  nomorRuangan String
  kategori     String
  lantai       String
  kapasitas    Int
  fasilitas    String[]
  fotoUrl      String?
  isAvailable  Boolean   @default(true)
  needsPermit  Boolean   @default(false)
  keterangan   String?
  bookings     Booking[]
}

model Booking {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  nama         String
  nim          String
  email        String
  hp           String
  instansi     String
  jabatan      String
  tanggal      String
  jamMulai     String
  jamSelesai   String
  kegiatan     String
  fileSuratUrl String
  status       String   @default("pending")
  catatanAdmin String?
  roomId       String
  userId       String?
  room         Room     @relation(fields: [roomId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("info")
  bookingId String?
}

model Profile {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  nama      String
  hp        String   @default("")
  nim       String   @default("")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   // Diarahkan ke user yang menerima notifikasi
  title     String   // Contoh: "Peminjaman Disetujui 🎉" atau "Peminjaman Ditolak ❌"
  message   String   // Contoh: "Pengajuan ruangan Aula Gedung A telah disetujui oleh admin."
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Jika kamu punya relasi ke model User, bisa ditambahkan di sini
  // user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}